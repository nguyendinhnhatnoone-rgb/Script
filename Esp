-- LOGIC QUÉT ESP HIGHLIGHT (Đã tối ưu hóa luồng quét)
local function addESP(c)
    if not c or c:FindFirstChild("CRAB_RAINBOW_ESP") or A:GetPlayerFromCharacter(c) == C then return end
    local h = Instance.new("Highlight")
    h.Name = "CRAB_RAINBOW_ESP"
    h.FillColor = Color3.fromRGB(255, 0, 0)
    h.OutlineColor = Color3.fromRGB(255, 255, 255)
    h.FillTransparency = 0.4
    h.OutlineTransparency = 0
    h.Adornee = c
    h.Parent = c
end

local function removeESP(c) 
    if c and c:FindFirstChild("CRAB_RAINBOW_ESP") then 
        c.CRAB_RAINBOW_ESP:Destroy() 
    end 
end

task.spawn(function()
    while true do 
        pcall(function()
            for _, p in pairs(A:GetPlayers()) do 
                if p.Character then 
                    if T then addESP(p.Character) else removeESP(p.Character) end 
                end 
            end
        end)
        task.wait(EspDelay)
    end 
end)

A.PlayerRemoving:Connect(function(p) if p.Character then removeESP(p.Character) end end)

